# Copy to .env and adjust. Ports are read by the server (src/index.ts), the vite
# UI (ui/vite.config.ts), and scripts/stop.sh so `make start` and `make stop`
# always target the same ports.
#
# Keep PROXY_PORT off 8080 if something else (e.g. Zookeeper/Jetty) owns it.
PROXY_PORT=8081
UI_PORT=3000
VITE_PORT=5173
